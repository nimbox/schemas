{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.nimbox.com/preferences/v1/property.schema.json",
    "title": "Property",
    "description": "One Property entry in a preferences Schema. See docs/specification.md (Property Contract).",
    "type": "object",
    "required": ["type", "scope", "overridable"],
    "properties": {
        "type": {
            "description": "JSON value type of the property.",
            "type": "string",
            "enum": ["boolean", "integer", "number", "string", "array", "object", "any"]
        },
        "scope": {
            "description": "Owning scope: layer where resolution begins for this property.",
            "type": "string",
            "minLength": 1
        },
        "overridable": {
            "description": "Whether scopes downstream of `scope` may replace the value.",
            "type": "boolean"
        },
        "default": {
            "description": "Fallback value when no scope authors a value. Must satisfy `type`, `items`, declared constraints, and `enum`.",
            "type": ["boolean", "integer", "number", "string", "array", "object"]
        },
        "description": {
            "description": "Markdown text or `%key%` message reference.",
            "type": "string",
            "minLength": 1
        },
        "deprecationMessage": {
            "description": "Optional deprecation notice (key-or-text).",
            "type": "string",
            "minLength": 1
        },
        "order": {
            "description": "Optional sibling-ordering hint for hierarchical display.",
            "type": "number"
        },
        "items": {
            "description": "Element shape. Required when `type` is `array`; forbidden otherwise.",
            "$ref": "#/$defs/item"
        },
        "minItems": {
            "description": "Minimum array length. Only valid for array properties.",
            "type": "integer",
            "minimum": 0
        },
        "maxItems": {
            "description": "Maximum array length. Only valid for array properties.",
            "type": "integer",
            "minimum": 0
        }
    },
    "allOf": [
        {
            "if": {
                "required": ["type"],
                "properties": { "type": { "const": "array" } }
            },
            "then": { "required": ["items"] },
            "else": { "not": { "required": ["items"] } }
        },
        {
            "if": {
                "anyOf": [
                    { "required": ["minItems"] },
                    { "required": ["maxItems"] }
                ]
            },
            "then": {
                "required": ["type"],
                "properties": {
                    "type": { "const": "array" }
                }
            }
        },
        { "$ref": "#/$defs/scalarConstraints" }
    ],
    "additionalProperties": true,
    "$defs": {
        "item": {
            "title": "PropertyItem",
            "description": "Element shape for `array` properties. Element-level scalar constraints (enum, minimum/maximum, pattern, etc.) are declared here. Nested arrays are not supported; use `any` if elements may themselves be arrays.",
            "type": "object",
            "required": ["type"],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": ["boolean", "integer", "number", "string", "object", "any"]
                }
            },
            "allOf": [
                { "$ref": "#/$defs/scalarConstraints" }
            ],
            "unevaluatedProperties": false
        },
        "scalarConstraints": {
            "title": "ScalarConstraints",
            "description": "Constraints that apply to a single scalar value. Used at the property root for scalar properties, and on `items` for array properties (where they apply per element).",
            "type": "object",
            "properties": {
                "enum": {
                    "description": "Allowed values. Valid only when the in-context `type` is `integer` or `string`.",
                    "type": "array",
                    "minItems": 1
                },
                "enumLabels": {
                    "description": "Per-option short labels (key-or-text), aligned by index with `enum`.",
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                },
                "enumDescriptions": {
                    "description": "Per-option long help (key-or-text), aligned by index with `enum`.",
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                },
                "minimum": {
                    "description": "Inclusive lower bound. Valid only when the in-context `type` is `integer` or `number`.",
                    "type": "number"
                },
                "maximum": {
                    "description": "Inclusive upper bound. Valid only when the in-context `type` is `integer` or `number`.",
                    "type": "number"
                },
                "minLength": {
                    "description": "Minimum string length. Valid only when the in-context `type` is `string`.",
                    "type": "integer",
                    "minimum": 0
                },
                "maxLength": {
                    "description": "Maximum string length. Valid only when the in-context `type` is `string`.",
                    "type": "integer",
                    "minimum": 0
                },
                "pattern": {
                    "description": "Regular expression a string value must match. Valid only when the in-context `type` is `string`.",
                    "type": "string",
                    "format": "regex"
                },
                "patternErrorMessage": {
                    "description": "Diagnostic shown when `pattern` fails (key-or-text).",
                    "type": "string",
                    "minLength": 1
                },
                "format": {
                    "description": "Known string format. Valid only when the in-context `type` is `string`.",
                    "type": "string",
                    "enum": ["date", "time", "email", "uri", "ipv4"]
                }
            },
            "allOf": [
                {
                    "if": {
                        "anyOf": [
                            { "required": ["enumLabels"] },
                            { "required": ["enumDescriptions"] }
                        ]
                    },
                    "then": { "required": ["enum"] }
                },
                {
                    "if": { "required": ["enum"] },
                    "then": {
                        "required": ["type"],
                        "properties": {
                            "type": { "enum": ["integer", "string"] }
                        }
                    }
                },
                {
                    "if": {
                        "anyOf": [
                            { "required": ["minimum"] },
                            { "required": ["maximum"] }
                        ]
                    },
                    "then": {
                        "required": ["type"],
                        "properties": {
                            "type": { "enum": ["integer", "number"] }
                        }
                    }
                },
                {
                    "if": {
                        "anyOf": [
                            { "required": ["minLength"] },
                            { "required": ["maxLength"] },
                            { "required": ["pattern"] },
                            { "required": ["patternErrorMessage"] },
                            { "required": ["format"] }
                        ]
                    },
                    "then": {
                        "required": ["type"],
                        "properties": {
                            "type": { "const": "string" }
                        }
                    }
                }
            ]

        }
    }
}
